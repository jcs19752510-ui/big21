   ],
   "source": [
    "# try except는 중지시키지 않고, 끝까지 가기 위함. 정상 종료 위함.\n",
    "try:\n",
    "    a = [1, 2]\n",
    "    print(a[2])\n",
    "except IndexError :\n",
    "    print(\"인덱싱할 수 없습니다.\")  \n",
    "\n",
    "print('정상 종료')\n",
    "# 4/0"
   ]
  }
